# Reference only.
# Django does not auto-load this file in this repo.
# Export these variables from the shell, systemd or the process manager you use.

# Django
SECRET_KEY=change-me
DEBUG=False
ALLOWED_HOSTS=agenda.example.com,www.agenda.example.com
CSRF_TRUSTED_ORIGINS=https://agenda.example.com,https://www.agenda.example.com
WAGTAILADMIN_BASE_URL=https://agenda.example.com
TIME_ZONE=Europe/Madrid

# PostgreSQL
# Production should use PostgreSQL.
# If no POSTGRES_* variables are defined, the project falls back to local SQLite.
POSTGRES_DB=agenda_de_citas
POSTGRES_USER=agenda_de_citas
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer
POSTGRES_CONN_MAX_AGE=60

# Optional HTTPS flags
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# Keep False unless you explicitly want browser preload and have validated that decision.
SECURE_HSTS_PRELOAD=False
USE_X_FORWARDED_HOST=True
USE_X_FORWARDED_PORT=True
USE_X_FORWARDED_PROTO=True
